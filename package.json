{
  "name": "@earn-fi/agent-client",
  "version": "1.0.1",
  "description": "TypeScript client and CLI for the EarnFi Agent API — registration, x402 USDC paid job creates, polling, and creator actions.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "earnfi-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test:smoke": "npm run build && node scripts/smoke-live.mjs",
    "test:published": "node scripts/smoke-published.mjs"
  },
  "keywords": [
    "earnfi",
    "x402",
    "agent",
    "solana",
    "usdc",
    "human-in-the-loop",
    "microjobs"
  ],
  "license": "MIT",
  "homepage": "https://github.com/earnfidotfun/agent-client#readme",
  "bugs": {
    "url": "https://github.com/earnfidotfun/agent-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earnfidotfun/agent-client.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  }
}
